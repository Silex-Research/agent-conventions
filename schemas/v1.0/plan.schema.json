{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-conventions/schemas/v1.0/plan.schema.json",
  "title": "Plan",
  "description": "Orchestration plan metadata. Narrative lives in plan.md frontmatter; this schema validates that frontmatter.",
  "type": "object",
  "required": ["id", "title", "type", "tier", "status", "date", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{3}-(feat|fix|refactor|migration|infra)-[a-z0-9-]+$",
      "description": "YYYY-MM-DD-NNN-<type>-<kebab-name>"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "type": { "enum": ["feat", "fix", "refactor", "migration", "infra"] },
    "tier": { "enum": ["trivial", "local", "cross-cutting", "architectural", "p0"] },
    "status": { "enum": ["draft", "active", "ready_for_audit", "in_audit", "completed", "abandoned", "blocked"] },
    "date": { "type": "string", "format": "date" },
    "description": { "type": "string", "minLength": 10 },
    "motivation": { "type": "string" },
    "agents_required": {
      "type": "array",
      "items": { "enum": ["claude", "codex", "gemini", "grok", "oss-qwen", "oss-gemma4", "oss-nemotron", "oss-llama-guard", "oss-nomic-embed"] }
    },
    "human_gates": {
      "type": "array",
      "items": { "enum": ["pre_impl", "pre_merge", "on_escalation", "tier_promotion", "cost_trigger"] }
    },
    "quota_caps": {
      "type": "object",
      "description": "Per-model % weekly quota cap for this plan. OSS is unmetered (Ollama local).",
      "properties": {
        "claude": { "type": "number", "minimum": 0, "maximum": 100 },
        "codex": { "type": "number", "minimum": 0, "maximum": 100 },
        "gemini": { "type": "number", "minimum": 0, "maximum": 100 },
        "grok_calls": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "loop_caps": {
      "type": "object",
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 0 },
        "no_progress_threshold": { "type": "integer", "minimum": 1 },
        "wall_clock_hours": { "type": "number", "minimum": 0 },
        "hard_stop": {
          "type": "boolean",
          "description": "true = terminate at cap; false (default) = pause for human approval via INBOX.md, reset counters on approval."
        }
      },
      "additionalProperties": false
    },
    "privacy_tier": { "enum": ["public", "internal", "secret"] },
    "goal_type": {
      "enum": ["mechanical", "infra", "refactor", "parity", "new_feature", "migration", "incident"],
      "description": "Goal-completion governance category. When set to one of {parity, new_feature, migration, incident}, the plan must declare links.objective_contract pointing at an ObjectiveContract file. mechanical/infra/refactor plans don't require a contract; backward-compatible default is null/absent."
    },
    "protected_paths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Path patterns that require human approval to modify"
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "status"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "status": { "enum": ["open", "resolved", "deferred"] },
          "resolution": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "description": "Plan IDs this plan depends on" }
    },
    "links": {
      "type": "object",
      "properties": {
        "features": { "type": "string" },
        "decisions": { "type": "string" },
        "audits_dir": { "type": "string" },
        "evidence_dir": { "type": "string" },
        "objective_contract": {
          "type": "string",
          "description": "Path reference (relative to plan dir) to an ObjectiveContract JSON file. Required when goal_type ∈ {parity, new_feature, migration, incident}; the plan-level validator enforces presence + file-exists + ObjectiveContract validation."
        }
      }
    },
    "storage": {
      "type": "object",
      "description": "External storage backend for evidence > 100KB",
      "properties": {
        "backend": { "enum": ["firebase-storage", "r2", "local"] },
        "bucket": { "type": "string" },
        "prefix": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
